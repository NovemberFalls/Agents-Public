{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"<ABSOLUTE-PATH-TO>/hooks/orch_enforce.py\""
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python \"<ABSOLUTE-PATH-TO>/hooks/orch_enforce.py\""
          }
        ]
      }
    ]
  }
}
